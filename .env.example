# Get your free credentials at https://developers.brandfetch.com/dashboard
# Both keys are required for full functionality.

# Client ID — used for Logo API and Brand Search API (safe to expose in browser)
BRANDFETCH_CLIENT_ID=your_client_id_here

# API Key — used for Brand API and Transaction API (must stay server-side)
BRANDFETCH_API_KEY=your_api_key_here

# Optional — defaults to 3737
# PORT=3737
